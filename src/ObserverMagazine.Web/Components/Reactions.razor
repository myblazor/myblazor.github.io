@inject IAnalyticsService Analytics

@if (_reactions is not null)
{
    <div class="reactions-bar">
        @foreach (var (emoji, type) in ReactionTypes)
        {
            var count = _reactions.GetValueOrDefault(type, 0);
            <button class="reaction-btn @(_userReacted == type ? "reacted" : "")"
                    @onclick="() => React(type)"
                    title="@type">
                <span class="reaction-emoji">@emoji</span>
                @if (count > 0)
                {
                    <span class="reaction-count">@count</span>
                }
            </button>
        }
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private static readonly (string Emoji, string Type)[] ReactionTypes =
    [
        ("👍", "like"),
        ("❤️", "love"),
        ("🎉", "celebrate"),
        ("🤔", "thinking")
    ];

    private Dictionary<string, int>? _reactions;
    private string? _userReacted;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Slug)) return;

        _reactions = await Analytics.GetReactionsAsync(Slug);
        // If backend returned null, reactions stays null and the UI is hidden
    }

    private async Task React(string type)
    {
        if (_reactions is null || _userReacted == type) return;

        _userReacted = type;
        await Analytics.AddReactionAsync(Slug, type);

        // Optimistic update
        _reactions[type] = _reactions.GetValueOrDefault(type, 0) + 1;
        await Analytics.TrackInteractionAsync("Reaction", $"{Slug}: {type}");
    }
}
