@page "/showcase"
@inject ILogger<Showcase> Logger
@inject IAnalyticsService Analytics
@inject IJSRuntime Js
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Showcase — My Blazor Magazine</PageTitle>

<h1>Product Catalog Showcase</h1>
<p>
    A paginated, sortable, filterable product catalog with column visibility controls and
    full CRUD. Demonstrates patterns real e-commerce applications need. Data is persisted in
    your browser's local storage.
</p>

@* ---- Toolbar ---- *@
<div class="sc-toolbar">
    <div class="sc-toolbar-left">
        <button class="btn btn-primary btn-sm" @onclick="NavigateToNew">+ New Product</button>
        <button class="btn btn-outline btn-sm" @onclick="ResetData">Reset Data</button>
        <span class="sc-count">@_filteredProducts.Count of @_allProducts.Count items</span>
    </div>
    <div class="sc-toolbar-right">
        <button class="btn btn-outline btn-sm" @onclick="ToggleFilters">
            @(_showFilters ? "Hide Filters" : "Show Filters")
        </button>
        <div class="sc-col-toggle">
            <button class="btn btn-outline btn-sm" @onclick="ToggleColumnPicker">Columns ▾</button>
            @if (_showColumnPicker)
            {
                <div class="sc-col-backdrop" @onclick="() => _showColumnPicker = false"></div>
                <div class="sc-col-dropdown" @onclick:stopPropagation="true">
                    @foreach (var col in _columns)
                    {
                        <label class="sc-col-option">
                            <input type="checkbox" checked="@col.Visible"
                                   @onchange="e => ToggleColumn(col, (bool)(e.Value ?? false))" />
                            @col.Header
                        </label>
                    }
                    <hr />
                    <button class="btn btn-outline btn-sm sc-col-restore" @onclick="RestoreColumnDefaults">
                        Restore Defaults
                    </button>
                </div>
            }
        </div>
        <div class="sc-page-size">
            <label>Per page:</label>
            <select value="@_pageSize" @onchange="OnPageSizeChanged">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>
    </div>
</div>

@* ---- Filter panel (collapsible, works on desktop + mobile) ---- *@
@if (_showFilters)
{
    <div class="sc-filter-panel">
        <div class="sc-filter-panel-header">
            <strong>Filters</strong>
            <button class="btn btn-outline btn-sm" @onclick="ClearFilters" title="Clear all filters">
                Clear All Filters
            </button>
        </div>
        <div class="sc-filter-grid">
            @foreach (var col in _columns.Where(c => c.Visible))
            {
                @if (col.FilterKind == FilterKind.Text)
                {
                    <div class="sc-filter-row">
                        <label class="sc-filter-label">@col.Header</label>
                        <input type="text" class="sc-filter-input"
                               placeholder="Filter @col.Header..."
                               value="@col.FilterText"
                               @oninput="e => OnFilterTextChanged(col, e.Value?.ToString() ?? string.Empty)" />
                    </div>
                }
                else if (col.FilterKind == FilterKind.Range)
                {
                    <div class="sc-filter-row">
                        <label class="sc-filter-label">@col.Header</label>
                        <div class="sc-range-inputs">
                            <input type="number" class="sc-filter-input"
                                   placeholder="Min"
                                   value="@col.FilterMin"
                                   @oninput="e => OnFilterMinChanged(col, e.Value?.ToString() ?? string.Empty)" />
                            <span class="sc-range-sep">–</span>
                            <input type="number" class="sc-filter-input"
                                   placeholder="Max"
                                   value="@col.FilterMax"
                                   @oninput="e => OnFilterMaxChanged(col, e.Value?.ToString() ?? string.Empty)" />
                        </div>
                    </div>
                }
                else if (col.FilterKind == FilterKind.Select)
                {
                    <div class="sc-filter-row">
                        <label class="sc-filter-label">@col.Header</label>
                        <select class="sc-filter-input"
                                value="@col.FilterText"
                                @onchange="e => OnFilterTextChanged(col, e.Value?.ToString() ?? string.Empty)">
                            <option value="">All</option>
                            @foreach (var opt in col.SelectOptions)
                            {
                                <option value="@opt">@opt</option>
                            }
                        </select>
                    </div>
                }
            }
        </div>
    </div>
}

@* ---- Table ---- *@
<div class="sc-table-wrap">
    <table class="sc-table">
        <thead>
            <tr>
                @foreach (var col in _columns.Where(c => c.Visible))
                {
                    <th class="@(col.Numeric ? "sc-num" : string.Empty) sc-sortable"
                        style="@ColStyle(col)"
                        @onclick="() => SortBy(col)">
                        @col.Header
                        @if (_sortColumn == col.Key)
                        {
                            <span class="sc-sort-arrow">@(_sortAsc ? "▲" : "▼")</span>
                        }
                    </th>
                }
                <th class="sc-actions-col">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (_pagedProducts.Count == 0)
            {
                <tr>
                    <td colspan="@(_columns.Count(c => c.Visible) + 1)" class="sc-empty">
                        No products match your filters.
                    </td>
                </tr>
            }
            @foreach (var p in _pagedProducts)
            {
                <tr @onclick="() => NavigateToDetail(p.Id)" class="sc-clickable-row">
                    @foreach (var col in _columns.Where(c => c.Visible))
                    {
                        <td class="@(col.Numeric ? "sc-num" : string.Empty)"
                            data-label="@col.Header">
                            @col.Render(p)
                        </td>
                    }
                    <td class="sc-actions" data-label="Actions" @onclick:stopPropagation="true">
                        <button class="btn btn-outline btn-sm" @onclick="() => NavigateToDetail(p.Id)">Edit</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDelete(p)">Del</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@* ---- Pagination ---- *@
<div class="sc-pagination">
    <button class="btn btn-outline btn-sm" @onclick="FirstPage" disabled="@(_currentPage <= 1)">« First</button>
    <button class="btn btn-outline btn-sm" @onclick="PrevPage" disabled="@(_currentPage <= 1)">‹ Prev</button>
    <span class="sc-page-info">Page @_currentPage of @_totalPages</span>
    <button class="btn btn-outline btn-sm" @onclick="NextPage" disabled="@(_currentPage >= _totalPages)">Next ›</button>
    <button class="btn btn-outline btn-sm" @onclick="LastPage" disabled="@(_currentPage >= _totalPages)">Last »</button>
</div>

@* ---- Delete confirmation overlay ---- *@
@if (_deleteTarget is not null)
{
    <div class="sc-overlay" @onclick="CancelDelete">
        <div class="sc-dialog" @onclick:stopPropagation="true">
            <h4>Delete product?</h4>
            <p>Are you sure you want to delete <strong>@_deleteTarget.Name</strong> (@_deleteTarget.Sku)?</p>
            <div style="display:flex;gap:0.5rem;justify-content:flex-end;">
                <button class="btn btn-outline btn-sm" @onclick="CancelDelete">Cancel</button>
                <button class="btn btn-danger btn-sm" @onclick="ExecuteDelete">Delete</button>
            </div>
        </div>
    </div>
}

@code {
    private const string StorageKey = "observer-catalog-products";
    private const string PrefsKey = "observer-showcase-prefs";

    private List<CatalogProduct> _allProducts = [];
    private List<CatalogProduct> _filteredProducts = [];
    private List<CatalogProduct> _pagedProducts = [];

    private int _pageSize = 20;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private string _sortColumn = "Name";
    private bool _sortAsc = true;
    private bool _showColumnPicker;
    private bool _showFilters = true;
    private CatalogProduct? _deleteTarget;

    // --- Column definitions ---
    private List<ColumnDef> _columns = [];

    // Track default visibility for "Restore Defaults"
    private Dictionary<string, bool> _defaultVisibility = new();

    protected override async Task OnInitializedAsync()
    {
        InitColumns();
        await LoadProducts();
        await LoadPrefs();
        ApplyFilterAndSort();
        await Analytics.TrackPageViewAsync("Showcase");
    }

    private void InitColumns()
    {
        _columns =
        [
            new("Sku", "SKU", p => p.Sku, false, FilterKind.Text) { MinWidth = "90px" },
            new("Name", "Name", p => p.Name, false, FilterKind.Text) { MinWidth = "160px" },
            new("Brand", "Brand", p => p.Brand, false, FilterKind.Text) { MinWidth = "100px" },
            new("Category", "Category", p => p.Category, false, FilterKind.Select)
            {
                MinWidth = "120px",
                SelectOptions = ["Electronics", "Furniture", "Clothing", "Home & Kitchen", "Sports & Outdoors", "Office Supplies", "Accessories"]
            },
            new("Price", "Price", p => p.Price.ToString("C"), true, FilterKind.Range) { MinWidth = "100px" },
            new("Stock", "Stock", p => p.Stock.ToString(), true, FilterKind.Range) { MinWidth = "80px" },
            new("Rating", "Rating", p => p.Rating.ToString("F1"), true, FilterKind.Range) { MinWidth = "70px" },
            new("ReviewCount", "Reviews", p => p.ReviewCount.ToString("N0"), true, FilterKind.Range) { MinWidth = "80px", Visible = false },
            new("WeightKg", "Weight (kg)", p => p.WeightKg.ToString("F2"), true, FilterKind.Range) { MinWidth = "90px", Visible = false },
            new("Color", "Color", p => p.Color, false, FilterKind.Text) { MinWidth = "90px", Visible = false },
            new("WarrantyMonths", "Warranty", p => p.WarrantyMonths > 0 ? $"{p.WarrantyMonths} mo" : "None", true, FilterKind.Range)
            {
                MinWidth = "80px",
                Visible = false
            },
            new("DateAdded", "Date Added", p => p.DateAdded.ToString("yyyy-MM-dd"), false, FilterKind.Text)
            {
                MinWidth = "100px",
                Visible = false
            },
            new("Status", "Status", p => p.Status, false, FilterKind.Select)
            {
                MinWidth = "90px",
                SelectOptions = ["Active", "Draft", "Archived", "Out of Stock"]
            },
        ];

        // Save defaults
        _defaultVisibility = _columns.ToDictionary(c => c.Key, c => c.Visible);
    }

    // --- Product persistence ---

    private async Task LoadProducts()
    {
        try
        {
            var json = await Js.InvokeAsync<string?>("localStorage.getItem", StorageKey);
            if (!string.IsNullOrEmpty(json))
            {
                var loaded = System.Text.Json.JsonSerializer.Deserialize<List<CatalogProduct>>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
                if (loaded is { Count: > 0 })
                {
                    _allProducts = loaded;
                    return;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not load catalog from local storage");
        }

        _allProducts = ProductDataGenerator.Generate();
        await SaveProducts();
    }

    private async Task SaveProducts()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_allProducts,
                new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
            await Js.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not save catalog to local storage");
        }
    }

    // --- Preferences persistence ---

    private async Task LoadPrefs()
    {
        try
        {
            var json = await Js.InvokeAsync<string?>("localStorage.getItem", PrefsKey);
            if (string.IsNullOrEmpty(json)) return;

            var prefs = System.Text.Json.JsonSerializer.Deserialize<ShowcasePrefs>(json,
                new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
            if (prefs is null) return;

            if (prefs.PageSize is > 0) _pageSize = prefs.PageSize.Value;
            if (!string.IsNullOrEmpty(prefs.SortColumn)) _sortColumn = prefs.SortColumn;
            if (prefs.SortAsc is not null) _sortAsc = prefs.SortAsc.Value;
            if (prefs.ShowFilters is not null) _showFilters = prefs.ShowFilters.Value;

            if (prefs.ColumnVisibility is not null)
            {
                foreach (var col in _columns)
                {
                    if (prefs.ColumnVisibility.TryGetValue(col.Key, out var vis))
                        col.Visible = vis;
                }
            }

            if (prefs.Filters is not null)
            {
                foreach (var col in _columns)
                {
                    if (prefs.Filters.TryGetValue(col.Key, out var f))
                    {
                        col.FilterText = f.Text ?? string.Empty;
                        col.FilterMin = f.Min ?? string.Empty;
                        col.FilterMax = f.Max ?? string.Empty;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not load showcase preferences");
        }
    }

    private async Task SavePrefs()
    {
        try
        {
            var prefs = new ShowcasePrefs
            {
                PageSize = _pageSize,
                SortColumn = _sortColumn,
                SortAsc = _sortAsc,
                ShowFilters = _showFilters,
                ColumnVisibility = _columns.ToDictionary(c => c.Key, c => c.Visible),
                Filters = _columns
                    .Where(c => !string.IsNullOrEmpty(c.FilterText) || !string.IsNullOrEmpty(c.FilterMin) || !string.IsNullOrEmpty(c.FilterMax))
                    .ToDictionary(c => c.Key, c => new FilterState
                    {
                        Text = string.IsNullOrEmpty(c.FilterText) ? null : c.FilterText,
                        Min = string.IsNullOrEmpty(c.FilterMin) ? null : c.FilterMin,
                        Max = string.IsNullOrEmpty(c.FilterMax) ? null : c.FilterMax,
                    })
            };

            var json = System.Text.Json.JsonSerializer.Serialize(prefs,
                new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
            await Js.InvokeVoidAsync("localStorage.setItem", PrefsKey, json);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not save showcase preferences");
        }
    }

    // --- Filter / sort / paginate ---

    private void ApplyFilterAndSort()
    {
        IEnumerable<CatalogProduct> result = _allProducts;

        foreach (var col in _columns)
        {
            if (col.FilterKind == FilterKind.Text && !string.IsNullOrWhiteSpace(col.FilterText))
            {
                var term = col.FilterText;
                result = col.Key switch
                {
                    "Sku" => result.Where(p => p.Sku.Contains(term, StringComparison.OrdinalIgnoreCase)),
                    "Name" => result.Where(p => p.Name.Contains(term, StringComparison.OrdinalIgnoreCase)),
                    "Brand" => result.Where(p => p.Brand.Contains(term, StringComparison.OrdinalIgnoreCase)),
                    "Color" => result.Where(p => p.Color.Contains(term, StringComparison.OrdinalIgnoreCase)),
                    "DateAdded" => result.Where(p => p.DateAdded.ToString("yyyy-MM-dd").Contains(term, StringComparison.OrdinalIgnoreCase)),
                    _ => result
                };
            }
            else if (col.FilterKind == FilterKind.Select && !string.IsNullOrWhiteSpace(col.FilterText))
            {
                var term = col.FilterText;
                result = col.Key switch
                {
                    "Category" => result.Where(p => p.Category.Equals(term, StringComparison.OrdinalIgnoreCase)),
                    "Status" => result.Where(p => p.Status.Equals(term, StringComparison.OrdinalIgnoreCase)),
                    _ => result
                };
            }
            else if (col.FilterKind == FilterKind.Range)
            {
                if (double.TryParse(col.FilterMin, out var min))
                {
                    result = col.Key switch
                    {
                        "Price" => result.Where(p => (double)p.Price >= min),
                        "Stock" => result.Where(p => p.Stock >= min),
                        "Rating" => result.Where(p => p.Rating >= min),
                        "ReviewCount" => result.Where(p => p.ReviewCount >= min),
                        "WeightKg" => result.Where(p => p.WeightKg >= min),
                        "WarrantyMonths" => result.Where(p => p.WarrantyMonths >= min),
                        _ => result
                    };
                }

                if (double.TryParse(col.FilterMax, out var max))
                {
                    result = col.Key switch
                    {
                        "Price" => result.Where(p => (double)p.Price <= max),
                        "Stock" => result.Where(p => p.Stock <= max),
                        "Rating" => result.Where(p => p.Rating <= max),
                        "ReviewCount" => result.Where(p => p.ReviewCount <= max),
                        "WeightKg" => result.Where(p => p.WeightKg <= max),
                        "WarrantyMonths" => result.Where(p => p.WarrantyMonths <= max),
                        _ => result
                    };
                }
            }
        }

        // Sort
        result = _sortColumn switch
        {
            "Sku" => _sortAsc ? result.OrderBy(p => p.Sku) : result.OrderByDescending(p => p.Sku),
            "Name" => _sortAsc ? result.OrderBy(p => p.Name) : result.OrderByDescending(p => p.Name),
            "Brand" => _sortAsc ? result.OrderBy(p => p.Brand) : result.OrderByDescending(p => p.Brand),
            "Category" => _sortAsc ? result.OrderBy(p => p.Category) : result.OrderByDescending(p => p.Category),
            "Price" => _sortAsc ? result.OrderBy(p => p.Price) : result.OrderByDescending(p => p.Price),
            "Stock" => _sortAsc ? result.OrderBy(p => p.Stock) : result.OrderByDescending(p => p.Stock),
            "Rating" => _sortAsc ? result.OrderBy(p => p.Rating) : result.OrderByDescending(p => p.Rating),
            "ReviewCount" => _sortAsc ? result.OrderBy(p => p.ReviewCount) : result.OrderByDescending(p => p.ReviewCount),
            "WeightKg" => _sortAsc ? result.OrderBy(p => p.WeightKg) : result.OrderByDescending(p => p.WeightKg),
            "Color" => _sortAsc ? result.OrderBy(p => p.Color) : result.OrderByDescending(p => p.Color),
            "WarrantyMonths" => _sortAsc ? result.OrderBy(p => p.WarrantyMonths) : result.OrderByDescending(p => p.WarrantyMonths),
            "DateAdded" => _sortAsc ? result.OrderBy(p => p.DateAdded) : result.OrderByDescending(p => p.DateAdded),
            "Status" => _sortAsc ? result.OrderBy(p => p.Status) : result.OrderByDescending(p => p.Status),
            _ => result
        };

        _filteredProducts = result.ToList();
        _totalPages = Math.Max(1, (int)Math.Ceiling(_filteredProducts.Count / (double)_pageSize));
        if (_currentPage > _totalPages) _currentPage = _totalPages;
        if (_currentPage < 1) _currentPage = 1;

        _pagedProducts = _filteredProducts
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();
    }

    // --- Event handlers ---

    private async Task SortBy(ColumnDef col)
    {
        if (_sortColumn == col.Key)
            _sortAsc = !_sortAsc;
        else
        {
            _sortColumn = col.Key;
            _sortAsc = true;
        }
        _currentPage = 1;
        ApplyFilterAndSort();
        await SavePrefs();
    }

    private async Task OnFilterTextChanged(ColumnDef col, string value)
    {
        col.FilterText = value;
        _currentPage = 1;
        ApplyFilterAndSort();
        await SavePrefs();
    }

    private async Task OnFilterMinChanged(ColumnDef col, string value)
    {
        col.FilterMin = value;
        _currentPage = 1;
        ApplyFilterAndSort();
        await SavePrefs();
    }

    private async Task OnFilterMaxChanged(ColumnDef col, string value)
    {
        col.FilterMax = value;
        _currentPage = 1;
        ApplyFilterAndSort();
        await SavePrefs();
    }

    private async Task ClearFilters()
    {
        foreach (var col in _columns)
        {
            col.FilterText = string.Empty;
            col.FilterMin = string.Empty;
            col.FilterMax = string.Empty;
        }
        _currentPage = 1;
        ApplyFilterAndSort();
        await SavePrefs();
    }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size) && size > 0)
        {
            _pageSize = size;
            _currentPage = 1;
            ApplyFilterAndSort();
            await SavePrefs();
        }
    }

    private void FirstPage() { _currentPage = 1; ApplyFilterAndSort(); }
    private void PrevPage() { if (_currentPage > 1) { _currentPage--; ApplyFilterAndSort(); } }
    private void NextPage() { if (_currentPage < _totalPages) { _currentPage++; ApplyFilterAndSort(); } }
    private void LastPage() { _currentPage = _totalPages; ApplyFilterAndSort(); }

    private async Task ToggleFilters()
    {
        _showFilters = !_showFilters;
        await SavePrefs();
    }

    private void ToggleColumnPicker() => _showColumnPicker = !_showColumnPicker;

    private async Task ToggleColumn(ColumnDef col, bool visible)
    {
        col.Visible = visible;
        await SavePrefs();
    }

    private async Task RestoreColumnDefaults()
    {
        foreach (var col in _columns)
        {
            if (_defaultVisibility.TryGetValue(col.Key, out var vis))
                col.Visible = vis;
            col.FilterText = string.Empty;
            col.FilterMin = string.Empty;
            col.FilterMax = string.Empty;
        }
        _sortColumn = "Name";
        _sortAsc = true;
        _pageSize = 20;
        _currentPage = 1;
        _showColumnPicker = false;
        ApplyFilterAndSort();
        await SavePrefs();
    }

    private void NavigateToDetail(Guid id) => Nav.NavigateTo($"showcase/{id}");
    private void NavigateToNew() => Nav.NavigateTo("showcase/new");

    private void ConfirmDelete(CatalogProduct p) => _deleteTarget = p;
    private void CancelDelete() => _deleteTarget = null;

    private async Task ExecuteDelete()
    {
        if (_deleteTarget is not null)
        {
            _allProducts.RemoveAll(p => p.Id == _deleteTarget.Id);
            _deleteTarget = null;
            ApplyFilterAndSort();
            await SaveProducts();
        }
    }

    private async Task ResetData()
    {
        try { await Js.InvokeVoidAsync("localStorage.removeItem", StorageKey); }
        catch { /* best effort */ }

        _allProducts = ProductDataGenerator.Generate();
        _currentPage = 1;
        await ClearFilters();
        await SaveProducts();
    }

    private static string ColStyle(ColumnDef col) =>
        string.IsNullOrEmpty(col.MinWidth) ? string.Empty : $"min-width:{col.MinWidth}";

    public void Dispose()
    {
        // Nothing to dispose for now, but good practice to implement IDisposable
    }

    // --- Column definition model ---

    public enum FilterKind { Text, Range, Select }

    public sealed class ColumnDef(string key, string header, Func<CatalogProduct, string> render, bool numeric, FilterKind filterKind)
    {
        public string Key { get; } = key;
        public string Header { get; } = header;
        public bool Numeric { get; } = numeric;
        public FilterKind FilterKind { get; } = filterKind;
        public bool Visible { get; set; } = true;
        public string FilterText { get; set; } = string.Empty;
        public string FilterMin { get; set; } = string.Empty;
        public string FilterMax { get; set; } = string.Empty;
        public string MinWidth { get; set; } = string.Empty;
        public string[] SelectOptions { get; set; } = [];
        public string Render(CatalogProduct p) => render(p);
    }

    // --- Preferences DTO ---

    public sealed class ShowcasePrefs
    {
        public int? PageSize { get; set; }
        public string? SortColumn { get; set; }
        public bool? SortAsc { get; set; }
        public bool? ShowFilters { get; set; }
        public Dictionary<string, bool>? ColumnVisibility { get; set; }
        public Dictionary<string, FilterState>? Filters { get; set; }
    }

    public sealed class FilterState
    {
        public string? Text { get; set; }
        public string? Min { get; set; }
        public string? Max { get; set; }
    }
}
